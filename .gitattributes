# Linguist overrides for GitHub language statistics.
#
# `scripts/render_promo.mjs` is a local build/render helper (generates the
# promo image), not part of the published package. Marking it as
# `linguist-generated` keeps the repository listed as pure Python, which
# matches the project's "pure Python scientific computing" positioning.

scripts/render_promo.mjs linguist-generated=true

# Line-ending normalization. Normalize all text to LF in the repo so the
# same blob checks out identically on every platform; Git still hands the
# working copy the OS-preferred ending via core.autocrlf where configured.
# This prevents the "LF will be replaced by CRLF" warnings and the noisy
# whole-file diffs that pure line-ending flips cause.
* text=auto eol=lf

# Windows-only scripts keep their native CRLF.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary assets — never normalize, never diff as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.mp4   binary
*.webm  binary
*.zip   binary
*.gz    binary
*.whl   binary
*.sqlite binary
